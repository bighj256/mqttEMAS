}

QGroupBox {
    border: 2px solid #d1d9e6;
    border-radius: 10px;
    margin-top: 10px;
    padding-top: 20px;
    background-color: white;
    font-weight: bold;
    color: #2c3e50;
    font-size: 12pt;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 20px;
    padding: 0 15px 0 15px;
    background-color: white;
}

QLabel {
    font-size: 11pt;
}

#titleLabel {
    font-size: 20pt;
    font-weight: bold;
    color: #2c3e50;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #3498db, stop:1 #2ecc71);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

#tempValueLabel, #humidityValueLabel, #stateLabel {
    font-size: 36pt;
    font-weight: bold;
}

#statusLabel {
    font-size: 12pt;
    font-weight: bold;
    padding: 8px 15px;
    border-radius: 20px;
}</string>
